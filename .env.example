# Copy to .env and fill with your Supabase project values (same as the web app).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alpha Vantage API key for stocks, commodities, and USD/BRL exchange rate.
# Get a free key at https://www.alphavantage.co/support/#api-key
EXPO_PUBLIC_ALPHA_VANTAGE_KEY=VXUKX67EX36FM7RA

# Academy access: free (default, launch) or paid (requires profiles.academy_unlocked_at / grandfathered + payment webhook)
# EXPO_PUBLIC_ACADEMY_ACCESS_MODE=free

# Vertex Academy — resumos em áudio (MP3 por book id: f-1.mp3, i-1.mp3, …)
# URL pública até à pasta summaries (sem nome de ficheiro). Ver docs/academy-audio.md
# EXPO_PUBLIC_ACADEMY_AUDIO_BASE_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/academy-audio/summaries
